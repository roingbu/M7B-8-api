[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = https://github.com/ultralytics/ultralytics
	fetch = +refs/heads/*:refs/remotes/origin/*
[gc]
	auto = 0
[includeIf "gitdir:/home/runner/work/ultralytics/ultralytics/.git"]
	path = /home/runner/work/_temp/git-credentials-12fd18e0-2ba5-4dac-be58-d2477f961607.config
[includeIf "gitdir:/home/runner/work/ultralytics/ultralytics/.git/worktrees/*"]
	path = /home/runner/work/_temp/git-credentials-12fd18e0-2ba5-4dac-be58-d2477f961607.config
[includeIf "gitdir:/github/workspace/.git"]
	path = /github/runner_temp/git-credentials-12fd18e0-2ba5-4dac-be58-d2477f961607.config
[includeIf "gitdir:/github/workspace/.git/worktrees/*"]
	path = /github/runner_temp/git-credentials-12fd18e0-2ba5-4dac-be58-d2477f961607.config
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
